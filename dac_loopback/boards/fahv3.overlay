#include <zephyr/dt-bindings/dma/stm32_dma.h>

/ {
	aliases {
		codec0 = &dac_audio1;
	};
};

/*
 * DAC1 CH1 DMA: DMA1 stream 5, channel 7 (STM32F7 RM, Table 27).
 * Timer 6 update event (TRGO) triggers DAC conversions at sample_rate Hz.
 */
&dac_audio1 {
	dmas = <&dma1 5 7
		(STM32_DMA_PERIPH_TX | STM32_DMA_16BITS | STM32_DMA_PRIORITY_HIGH)
		0>;
	dma-names = "tx";
	pinctrl-0 = <&dac_out1_pa4>;
	pinctrl-names = "default";
	status = "okay";
};

&dma1 {
	status = "okay";
};

/* Hand DAC1 hardware to the audio driver; disable the plain DAC driver */
&dac1 {
	status = "disabled";
};

/*
 * ADC1 IN5 on PA5 — loopback from DAC output PA4 (temporary solder wire).
 * Overrides the board default pinctrl (PB1/IN9) for this sample only.
 */
&adc1 {
	pinctrl-0 = <&adc1_in5_pa5>;
	pinctrl-names = "default";
	st,adc-clock-source = "SYNC";
	st,adc-prescaler = <2>;
	status = "okay";
};
